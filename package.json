{
  "name": "clothing-management-server",
  "module": "src/index.ts",
  "version": "1.0.0",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "private": true,
  "description": "服装管理系统服务器端",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:check-sql": "bash scripts/check_pending_migrations.sh",
    "db:apply-sql": "bash scripts/apply_sql_migrations.sh",
    "db:seed": "bun run src/db/seed.ts",
    "test": "bun test",
    "lint": "bun run eslint . --ext .ts",
    "format": "bun run prettier --write ."
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qcloud-cos-sts": "^3.1.3",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  }
}
