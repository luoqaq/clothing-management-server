# 服务器配置
HOST=127.0.0.1
PORT=3000
NODE_ENV=production

# 数据库配置
DB_HOST=your-tencent-mysql-host
DB_PORT=3306
DB_USER=clothing_app
DB_PASSWORD=replace-with-strong-password
DB_NAME=clothing_management

# JWT 配置
JWT_SECRET=replace-with-a-random-long-secret
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://clothing.chuchu9.cn

# 腾讯云 COS 配置
COS_BUCKET=examplebucket-1250000000
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=https://cdn.example.com
COS_SECRET_ID=replace-with-cos-secret-id
COS_SECRET_KEY=replace-with-cos-secret-key
COS_STS_DURATION_SECONDS=1800
COS_UPLOAD_MAX_SIZE_MB=2

# AI 导入配置（OpenAI-compatible）
AI_IMPORT_BASE_URL=https://api.openai.com/v1
AI_IMPORT_API_KEY=replace-with-ai-import-api-key
AI_IMPORT_MODEL=gpt-4.1-mini
